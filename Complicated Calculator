print("Welcome to my Calculator")
type = input("Do you want to do only single operation or multiple operations? ").lower()   # Single or Series
print("Actions are + | - | * | / | % | // | exponent | root")    # Action

# Conditions for Single operations
if type == "single":
    action = input("Enter the operation you want to do: ").lower()

    if action == "addition" or action == "+" or action == "substraction" or action == "-" or action == "multiplication" or action == "*" or action == "x":      # Conditions for + - *
        n = int(input("Enter the total number of numbers in order of operation: "))
        num1 = float(input("Enter number 1: "))

        for i in range (2 , n+1):
            num = float(input(f"Enter number {i}: "))
            i += 1 

            if action == "+" or "addition":
                num1 += num
            elif action == "-" or "substraction":
                num1 -= num
            elif action == "*" or action == "x" or "multiplication":
                num1 *= num
            else:
                pass

        if action == "+" or "addition":
            print(num1)
        elif action == "*" or action == "x" or "multiplication":
            print(num1)
        elif action == "-" or "substraction":
            print(num1)
        else:
            pass

    elif action == "exponent" or action == "^":     # Conditions for remaining actions
        base = float(input("Enter the base: "))
        power = float(input("Enter the power: "))
        print(base ** power)

    elif action == "/" or action == "division":
        neumerator = float(input("Enter neumerator: "))
        denominator = float(input("Enter denominator: "))
        try:
            neumerator/denominator
        except ZeroDivisionError:
            print("Divison by zero is not possible")
            quit()
        print(round(neumerator/denominator , 5))

    elif action == "//" or action == "quotient":
        neumerator = float(input("Enter neumerator: "))
        denominator = float(input("Enter denominator: "))
        try: 
            neumerator//denominator
        except ZeroDivisionError:
            print("Divison by zero is not possible!!")
            quit()
        print(neumerator//denominator )

    elif action == "%" or action == "remainder":
        neumerator = float(input("Enter neumerator "))
        denominator = float(input("Enter denominator "))
        try: 
            neumerator % denominator
        except ZeroDivisionError:
            print("Divison by zero is not possible!!")
            quit()
        print(neumerator % denominator)
    elif action == "root":
        base = float(input("Enter the base: "))
        power = int(input("Enter the power of root: "))
        print(base ** (1/power))
    else:
        print("Wrong selection!!")
        quit()

# Condition for Multiple operaions
elif type == "multiple":
    expression = input("Enter the Mathematical Expression: ")
    def tokenize(expression):
        tokens = []
        cur_num = ""
        for char in expression:
            if char.isdigit() or char == ".":
                cur_num += char
            else:
                if cur_num:
                    tokens.append(float(cur_num))
                    cur_num = ""
                elif char != "":
                    tokens.append(char)
        if cur_num:
            tokens.append(float(cur_num))
        return tokens 
    
    def evaluate(tokens):
        i = 0
        while i < len(tokens):
            if tokens[i] == "*":
                result = tokens[i - 1] * [i + 1]
                tokens[i - 1 : i + 2] = [result]
                i = 0
            elif tokens [i] == "/":
                result = tokens[i - 1] / [i + 1]
                tokens[i - 1 : i + 2] = [result]
                i = 0
            else:
                i += 1 
        i = 0
        while i < len(tokens):
            if tokens[i] == "+":
                result  = tokens[i - 1] + [i + 1]
                tokens[i - 1 : i + 2] = [result]
                i = 0
            elif tokens[i] == "-":
                result = tokens[i - 1] - [i + 2]
                tokens[i - 1 : i + 2] = [result]
                i = 0
            else:
                i += 1 
            return tokens[0]
    tokens = tokenize(expression)
    result = evaluate(tokens)
    print("The result is: " , result)
else:
    print("Wrong selection!!")
    quit()